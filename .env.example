# Gemini API key (required for agent + generate_steps tool)
GOOGLE_API_KEY=your-gemini-api-key

# Google Custom Search API (required for search_images tool)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
# Custom Search Engine ID - create at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_CX=your-search-engine-cx-id

# YouTube Data API v3 (required for search_youtube tool)
# Enable at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your-youtube-api-key

# Server config
HOST=0.0.0.0
PORT=8080
